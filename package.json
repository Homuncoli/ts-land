{
  "name": "ts-land",
  "version": "1.0.0",
  "description": "A starter template project for [Adventure.land](https://adventure.land/)",
  "main": "index.js",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "lint:write": "eslint . --ext .ts --fix",
    "prepare": "husky install",
    "build": "rimraf ./build && webpack --mode production",
    "build:dev": "rimraf ./build && webpack --mode development",
    "start": "npm run build && node build/bundle.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/preset-env": "^7.14.8",
    "@babel/preset-typescript": "^7.14.5",
    "@types/node": "^16.4.7",
    "@types/webpack": "^5.28.0",
    "@typescript-eslint/eslint-plugin": "^4.28.5",
    "@typescript-eslint/parser": "^4.28.5",
    "babel-loader": "^8.2.2",
    "eslint": "^7.31.0",
    "husky": "^7.0.1",
    "rimraf": "^3.0.2",
    "ts-node": "^10.1.0",
    "typescript": "^4.3.5",
    "webpack": "^5.47.1",
    "webpack-cli": "^4.7.2"
  }
}
